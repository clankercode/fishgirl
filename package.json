{
  "name": "fishgirl",
  "version": "0.1.0",
  "description": "A Bun CLI for rendering Mermaid diagrams with mermaid-cli.",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/fishgirl",
  "packageManager": "bun@1.3.13",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clankercode/fishgirl.git"
  },
  "bugs": {
    "url": "https://github.com/clankercode/fishgirl/issues"
  },
  "keywords": [
    "bun",
    "cli",
    "mermaid",
    "diagram",
    "svg",
    "png",
    "pdf"
  ],
  "files": [
    "dist",
    "index.ts",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build ./index.ts --target=bun --packages=external --outfile=dist/fishgirl.js",
    "prepack": "bun run typecheck && bun run build",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "fishgirl": "dist/fishgirl.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.0"
  }
}
